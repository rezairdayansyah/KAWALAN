# =====================================================
#  ENVIRONMENT VARIABLES - BOT KAWAL LINTAS
#  Salin file ini menjadi .env untuk development lokal
#  Di Railway, isi langsung di menu Variables
# =====================================================

# Token Bot Telegram (dari @BotFather)
BOT_TOKEN=8831757624:AAGrbIIVklEcXMBcI3LYpY_vClt-dqn-QMM

# ID Google Spreadsheet
# Ambil dari URL: https://docs.google.com/spreadsheets/d/INI_SHEET_ID/edit
SHEET_ID=1VDxLP2962kFAKdkINUHj4hHtdGJswbCAbEWrgu5ge0w

# CATATAN: Admin ID tidak perlu diisi di sini.
# Admin diatur langsung dari sheet MASTER kolom C (isi dengan kata: ADMIN)
# Contoh sheet MASTER:
#   Kolom A          | Kolom B        | Kolom C
#   688909275        | NAMA ADMIN     | ADMIN
#   123456789        | PENGAWAL A     | (kosong)

# URL Railway App (kosongkan untuk mode polling / development lokal)
# Contoh: https://kawal-lintasan.railway.app
WEBHOOK_URL=

# Google Service Account Credentials (isi satu baris JSON)
# Cara mendapatkan:
#   1. Buka https://console.cloud.google.com
#   2. Buat project baru
#   3. Aktifkan "Google Sheets API"
#   4. Buat Service Account → Download JSON key
#   5. Share spreadsheet ke email service account (editor)
#   6. Copy seluruh isi file JSON ke sini (satu baris)
GOOGLE_CREDENTIALS={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
